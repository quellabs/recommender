{
  "name": "quellabs/recommender",
  "description": "Collaborative filtering recommendation engine (item-based CF and Slope One) using CakePHP 5 database layer",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris",
      "email": "floris@quellabs.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "cakephp/database": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Recommender\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "di": {
        "provider": "Quellabs\\Recommender\\ServiceProvider",
        "config": "config/recommender.php"
      },
      "sculpt": {
        "provider": "Quellabs\\Recommender\\Sculpt\\RecommenderProvider",
        "config": [
          "config/database.php",
          "config/recommender.php"
        ]
      }
    }
  }
}